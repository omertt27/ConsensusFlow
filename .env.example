# ConsensusFlow — Environment Variables
# Copy this file to .env and fill in your API keys.
# ConsensusFlow uses python-dotenv to load these automatically.

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Alternative: GOOGLE_API_KEY=AIza...

# ── Cohere ────────────────────────────────────────────────────
# COHERE_API_KEY=...

# ── Local / Ollama ────────────────────────────────────────────
# OLLAMA_API_BASE=http://localhost:11434

# ── Azure OpenAI ─────────────────────────────────────────────
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-01

# ── Debug ─────────────────────────────────────────────────────
# Set to "1" to enable verbose LiteLLM logs and full tracebacks.
# CONSENSUSFLOW_DEBUG=0
